@page "/spare-parts"
@using SpareParts.Models
@using SpareParts.Data
@using Microsoft.EntityFrameworkCore
@inject AppDbContext DbContext
@rendermode InteractiveServer

<PageTitle>备件列表</PageTitle>

<h2>备件列表</h2>

<div class="mb-3 d-flex gap-2 align-items-center">
    <input class="form-control w-auto" style="min-width:260px" placeholder="搜索 物品编码/名称/类别/规格/供应商..." @bind="searchText" @bind:event="oninput" />
    <button class="btn btn-outline-secondary" @onclick="ClearSearch">清除</button>
    <a class="btn btn-primary ms-auto" href="/spare-parts/add">+ 新增备件</a>
</div>

<!-- Column visibility checkboxes -->
<div class="mb-2 d-flex flex-wrap gap-3 border rounded p-2 bg-light">
    <strong class="me-2">显示列：</strong>
    @foreach (var col in columns)
    {
        <label class="form-check-label me-3">
            <input type="checkbox" class="form-check-input me-1" @bind="col.Visible" />
            @col.Name
        </label>
    }
</div>

<div style="overflow-x:auto">
    <table class="table table-bordered table-hover table-sm">
        <thead class="table-dark">
            <tr>
                @foreach (var col in columns.Where(c => c.Visible))
                {
                    <th>@col.Name</th>
                }
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @if (!filteredItems.Any())
            {
                <tr><td colspan="99" class="text-center text-muted">暂无数据</td></tr>
            }
            @foreach (var item in filteredItems)
            {
                <tr>
                    @foreach (var col in columns.Where(c => c.Visible))
                    {
                        <td>@col.Getter(item)</td>
                    }
                    <td>
                        <a class="btn btn-sm btn-outline-primary" href="/spare-parts/edit/@item.备件ID">编辑</a>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteItem(item)">删除</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private string searchText = "";
    private List<备件动态> allItems = new();

    class ColumnDef
    {
        public string Name { get; set; } = "";
        public bool Visible { get; set; } = true;
        public Func<备件动态, object?> Getter { get; set; } = _ => "";
    }

    List<ColumnDef> columns = new();

    protected override async Task OnInitializedAsync()
    {
        columns = new List<ColumnDef>
        {
            new() { Name = "物品编码",     Visible = true,  Getter = x => x.物品编码 },
            new() { Name = "备件名称",     Visible = true,  Getter = x => x.备件名称 },
            new() { Name = "物资类别",     Visible = true,  Getter = x => x.物资类别 },
            new() { Name = "常用件类别",   Visible = false, Getter = x => x.常用件类别 },
            new() { Name = "单位",         Visible = true,  Getter = x => x.单位 },
            new() { Name = "统计数量",     Visible = true,  Getter = x => x.统计数量 },
            new() { Name = "结存数量",     Visible = true,  Getter = x => x.结存数量 },
            new() { Name = "单价",         Visible = true,  Getter = x => x.单价 },
            new() { Name = "金额",         Visible = true,  Getter = x => x.金额 },
            new() { Name = "仓库位置",     Visible = false, Getter = x => x.仓库位置 },
            new() { Name = "货架位置",     Visible = false, Getter = x => x.货架位置 },
            new() { Name = "规格型号",     Visible = true,  Getter = x => x.规格型号 },
            new() { Name = "供应商",       Visible = true,  Getter = x => x.供应商 },
            new() { Name = "滞留原因",     Visible = false, Getter = x => x.滞留原因 },
            new() { Name = "使用设备",     Visible = false, Getter = x => x.使用设备 },
            new() { Name = "入库年份",     Visible = false, Getter = x => x.入库年份 },
            new() { Name = "预计使用日期", Visible = false, Getter = x => x.预计使用日期 },
            new() { Name = "备注",         Visible = false, Getter = x => x.备注 },
            new() { Name = "品牌",         Visible = true,  Getter = x => x.品牌 },
            new() { Name = "申报人",       Visible = false, Getter = x => x.申报人 },
            new() { Name = "申报日期",     Visible = false, Getter = x => x.申报日期?.ToString("yyyy-MM-dd") },
            new() { Name = "到货日期",     Visible = false, Getter = x => x.到货日期?.ToString("yyyy-MM-dd") },
            new() { Name = "维修人员",     Visible = false, Getter = x => x.维修人员 },
            new() { Name = "领用时间",     Visible = false, Getter = x => x.领用时间?.ToString("yyyy-MM-dd") },
            new() { Name = "领用人",       Visible = false, Getter = x => x.领用人 },
        };

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        allItems = await DbContext.备件动态.AsNoTracking().ToListAsync();
    }

    private IEnumerable<备件动态> filteredItems =>
        string.IsNullOrWhiteSpace(searchText)
            ? allItems
            : allItems.Where(x =>
                x.物品编码.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                x.备件名称.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                x.物资类别.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                x.常用件类别.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                x.规格型号.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                x.供应商.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                x.品牌.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                x.使用设备.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                x.仓库位置.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                x.备注.Contains(searchText, StringComparison.OrdinalIgnoreCase));

    private void ClearSearch() => searchText = "";

    private async Task DeleteItem(备件动态 item)
    {
        DbContext.备件动态.Remove(item);
        await DbContext.SaveChangesAsync();
        await LoadDataAsync();
    }
}
